# App
APP_PORT=3000
NODE_ENV=production

# Database (MySQL)
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=hotel_user
DB_PASSWORD=CHANGE_ME_strong_password
DB_DATABASE=smart_hotel
DB_ROOT_PASSWORD=CHANGE_ME_root_password
DB_SYNC=false
DB_LOGGING=false

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_DB=0

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password

# WeChat Mini Program (optional)
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Volcengine Ark AI (optional)
ARK_API_KEY=
ARK_MODEL_ID=doubao-pro-4k

# Alipay H5 (optional — required when FEATURE_PAYMENT_ENABLED=true)
# ALIPAY_APP_ID: Your Alipay open-platform app ID
# ALIPAY_PRIVATE_KEY: RSA2 private key (no PEM headers, single line)
# ALIPAY_PUBLIC_KEY: Alipay platform public key for response verification
# ALIPAY_NOTIFY_URL: Public URL that Alipay will POST payment results to
# ALIPAY_RETURN_URL: Page user is redirected to after Alipay H5 payment
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/alipay-notify
ALIPAY_RETURN_URL=https://your-domain.com/orders

# WeChat Pay (optional — required when FEATURE_WECHAT_PAY_ENABLED=true)
# WECHAT_PAY_MCH_ID: WeChat Pay merchant ID
# WECHAT_PAY_API_KEY: API v3 key (32 chars)
# WECHAT_PAY_NOTIFY_URL: Public URL that WeChat will POST payment results to
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/payment/wechat-notify

# Features
FEATURE_AI_ENABLED=false
FEATURE_PAYMENT_ENABLED=false
FEATURE_WECHAT_LOGIN=false
