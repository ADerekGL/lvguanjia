# 智慧酒店管家服务平台环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# =========== 应用配置 ===========
NODE_ENV=development
APP_NAME=Smart Hotel Platform
APP_PORT=3000
WS_PORT=3001
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080

# =========== 数据库配置 ===========
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=hotel_user
DB_PASSWORD=hotel_password
DB_DATABASE=smart_hotel
DB_SYNC=true  # 开发环境设为 true，生产环境设为 false
DB_LOGGING=true

# =========== Redis 配置 ===========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
REDIS_DB=0

# =========== JWT 配置 ===========
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# =========== 微信配置 ===========
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
WECHAT_REDIRECT_URL=http://localhost:8080/auth/callback

# =========== AI 服务配置 (火山引擎) ===========
VOLCANO_ACCESS_KEY=your_volcano_access_key
VOLCANO_SECRET_KEY=your_volcano_secret_key
VOLCANO_ENDPOINT=ark.cn-beijing.volces.com
VOLCANO_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B

# AI 调用限制
AI_DAILY_LIMIT_PER_ROOM=50
AI_CACHE_TTL=86400  # 24小时

# =========== 文件存储配置 ===========
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760  # 10MB
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,audio/mpeg

# =========== 邮件配置 ===========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
MAIL_FROM=noreply@smart-hotel.com

# =========== 支付配置 ===========
# 微信支付
WXPAY_MCHID=your_mchid
WXPAY_API_KEY=your_api_key
WXPAY_CERT_PATH=./certs/apiclient_cert.pem
WXPAY_KEY_PATH=./certs/apiclient_key.pem

# =========== 监控配置 ===========
SENTRY_DSN=your_sentry_dsn
PROMETHEUS_PORT=9090

# =========== 功能开关 ===========
FEATURE_AI_ENABLED=true
FEATURE_PAYMENT_ENABLED=true
FEATURE_WECHAT_LOGIN=true